# Production (Vercel) build-time config — read by Vite (web/vite.config.ts envDir: "..").
# Bakes the Railway-hosted backend URL into the build so the deployed site talks to it
# by default, with NO ?server= query param needed. TESTNET demo backend; not a secret.
VITE_SERVER_URL=https://tempoflow-production.up.railway.app
