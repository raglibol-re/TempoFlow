# ─────────────────────────────────────────────────────────────
# FLOW — environment schema (Tempo TESTNET ONLY. Never mainnet.)
# Copy to .env and fill in. See docs/10-runbook.md.
# ─────────────────────────────────────────────────────────────

# --- Tempo testnet network ---
# RPC endpoint for the Tempo testnet (verify exact URL in MPP docs / runbook).
TEMPO_RPC_URL=https://rpc.testnet.tempo.xyz
TEMPO_CHAIN_ID=4217

# Currency token used for all micropayments (pathUSD on Tempo testnet).
FLOW_CURRENCY=0x20c0000000000000000000000000000000000000

# --- MPP server secret ---
# Secret key used by the mppx server to sign settlements / manage the channel store.
MPP_SECRET_KEY=

# --- Wallet roles (Tempo testnet private keys, 0x-prefixed) ---
# Generated + funded via `pnpm wallets:setup`. NEVER commit real keys.
CREATOR_PRIVATE_KEY=
VIEWER_PRIVATE_KEY=
ADVERTISER_PRIVATE_KEY=

# Optional collaborators for split-payment demo (Phase 3).
CREATOR_COLLAB_A_PRIVATE_KEY=
CREATOR_COLLAB_B_PRIVATE_KEY=

# --- Faucet / funding ---
# A pre-funded master key used in demo mode to fund ephemeral wallets,
# OR leave blank to use the public testnet faucet (see runbook).
FUNDING_MASTER_PRIVATE_KEY=
TEMPO_FAUCET_URL=

# --- Service config ---
SERVER_PORT=3000
SERVER_URL=http://localhost:3000
WEB_PORT=5173

# Pricing (USD per second), tunable for the demo.
PRICE_CREATOR_PER_SEC=0.002
PRICE_ATTENTION_PER_SEC=0.004
